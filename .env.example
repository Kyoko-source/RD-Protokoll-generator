# Copy this file to .env and set real secrets.
# Never commit .env to version control.
ADMIN_PASSWORD=your_secure_password_here

# Local development defaults
NANA_ENV=development
NANA_DB_PATH=nana.db

# Production must use a long random secret outside the database.
# Generate for example with:
# python -c "import secrets; print(secrets.token_urlsafe(48))"
NANA_DATA_KEY=

# Comma-separated HTTPS origins for production, for example:
# NANA_ALLOWED_ORIGINS=https://nana.example.de
NANA_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
